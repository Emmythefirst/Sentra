{
  "name": "emmy-zerion-cli",
  "version": "1.0.1",
  "description": "Zerion for AI agents and developers: hosted MCP docs, wallet-analysis skill, and a JSON-first CLI.",
  "author": "Zerion",
  "type": "module",
  "bin": {
    "zerion": "cli/zerion.js"
  },
  "files": [
    "cli/**/*.js",
    "cli/**/*.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test 'tests/**/*.test.mjs'",
    "test:unit": "node --test 'tests/unit/**/*.test.mjs'",
    "test:integration": "node --test 'tests/integration/**/*.test.mjs'",
    "test:integration:auth": "node --test tests/integration/auth.test.mjs",
    "prepublishOnly": "npm test",
    "server": "nodemon --exec \"cross-env TS_NODE_PROJECT=server/tsconfig.json node --loader ts-node/esm\" server/index.ts",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "imports": {
    "#zerion/*": "./*",
    "#zerion": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "zerion",
    "ai",
    "mcp",
    "wallet",
    "openclaw",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeriontech/zerion-ai.git"
  },
  "bugs": {
    "url": "https://github.com/zeriontech/zerion-ai/issues"
  },
  "homepage": "https://github.com/zeriontech/zerion-ai#readme",
  "license": "MIT",
  "dependencies": {
    "@jup-ag/api": "^6.0.48",
    "@open-wallet-standard/core": "^1.2.4",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@x402/evm": "^2.6.0",
    "@x402/fetch": "^2.6.0",
    "@x402/svm": "^2.8.0",
    "axios": "^1.15.2",
    "bs58": "^6.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mppx": "^0.6.2",
    "node-cron": "^4.2.1",
    "qrcode-terminal": "^0.12.0",
    "viem": "^2.0.0"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
